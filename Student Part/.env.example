# Retrieval
TOP_K=8
CHUNK_SIZE=1200
CHUNK_OVERLAP=180
MIN_QUESTION_PAPER_YEAR=2020

# OCR behavior for local RapidOCR question-paper OCR
RENDER_DPI=180
